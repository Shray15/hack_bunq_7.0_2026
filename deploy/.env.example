# Copy this file to deploy/.env (production) or deploy/.env.staging (staging)
# and fill in every value before running `make start-production` / `make start-staging`.
# Never commit a file that contains real secrets.

# --- Images ------------------------------------------------------------------
# Set to the Docker image tags you built and pushed to your registry.

# DONT CHANGE THESE
IMAGE=ghcr.io/<owner>/<repo>:main-abc1234
GROCERY_MCP_IMAGE=ghcr.io/<owner>/<repo>-grocery-mcp:main-abc1234
VERSION=main-abc1234
ENVIRONMENT=production

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=cooking
POSTGRES_DB=cooking
POSTGRES_PASSWORD=<>

# --- App ---------------------------------------------------------------------
JWT_SECRET=<long-random-string>
GROCERY_MCP_URL=http://grocery-mcp:8001/mcp

# --- DeepSeek (LLM — recipe brain) ------------------------------------------
DEEPSEEK_API_KEY=sk-...

# --- Image generation --------------------------------------------------------
GEMINI_API_KEY=AIza...

# --- bunq --------------------------------------------------------------------
BUNQ_ME_USERNAME=amit
BUNQ_USER_ID=
BUNQ_ACCOUNT_ID=
BUNQ_API_KEY=<bunq-api-key>



# --- Picnic (consumed by grocery-mcp). Use either an auth token (preferred,
#     survives 6+ months) OR email+password (triggers SMS 2FA at boot). -------
PICNIC_AUTH_TOKEN=<jwt-from-2fa-verification>
PICNIC_EMAIL=
PICNIC_PASSWORD=
