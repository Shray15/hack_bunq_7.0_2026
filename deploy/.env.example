# Reference for the .env that the GHA deploy workflow writes to /opt/app/.env on EC2.
# Do NOT commit a real .env. Set every value as a GitHub Actions Secret instead.

# --- Images (set automatically by GHA, no need to manage by hand) -----------
IMAGE=ghcr.io/<owner>/<repo>:main-abc1234
GROCERY_MCP_IMAGE=ghcr.io/<owner>/<repo>-grocery-mcp:main-abc1234
VERSION=main-abc1234
ENVIRONMENT=production

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=cooking
POSTGRES_DB=cooking
POSTGRES_PASSWORD=<long-random-string>

# --- App ---------------------------------------------------------------------
JWT_SECRET=<long-random-string>
GROCERY_MCP_URL=http://grocery-mcp:8001/mcp

# --- AWS Bedrock (used by backend; passed through to grocery-mcp for optional fuzzy matching) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=<secret>
AWS_SESSION_TOKEN=<session-token-if-using-temporary-credentials>
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
AGENTCORE_MEMORY_ROLE_ARN=arn:aws:iam::<account-id>:role/<role-name>
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- Image generation --------------------------------------------------------
GEMINI_API_KEY=AIza...

# --- bunq sandbox (consumed by grocery-mcp at boot via bootstrap_bunq.py) ----
BUNQ_API_KEY=<sandbox-api-key>

# --- Picnic (consumed by grocery-mcp). Use either an auth token (preferred,
#     survives 6+ months) OR email+password (will trigger SMS 2FA at boot). ---
PICNIC_AUTH_TOKEN=<jwt-from-2fa-verification>
PICNIC_EMAIL=
PICNIC_PASSWORD=
